{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "acesso/course-detail",
    "version": "1.0.0",
    "title": "Course Detail",
    "category": "acesso-blocks",
    "icon": "id-alt",
    "description": "Display comprehensive course information.",
    "keywords": [
        "course",
        "detail",
        "info",
        "curso"
    ],
    "supports": {
        "html": false,
        "align": [
            "wide",
            "full"
        ],
        "spacing": {
            "padding": true,
            "margin": true,
            "blockGap": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true,
            "__experimentalLetterSpacing": true,
            "__experimentalTextTransform": true
        }
    },
    "attributes": {
        "courseSource": {
            "type": "string",
            "default": "current"
        },
        "selectedCourse": {
            "type": "number",
            "default": 0
        },
        "displayStyle": {
            "type": "string",
            "default": "full"
        },
        "showHeader": {
            "type": "boolean",
            "default": true
        },
        "showStats": {
            "type": "boolean",
            "default": true
        },
        "showProvas": {
            "type": "boolean",
            "default": true
        },
        "showClassificacao": {
            "type": "boolean",
            "default": true
        },
        "showFormula": {
            "type": "boolean",
            "default": true
        },
        "showPrerequisitos": {
            "type": "boolean",
            "default": true
        },
        "showDescricao": {
            "type": "boolean",
            "default": true
        },
        "showSaidas": {
            "type": "boolean",
            "default": true
        },
        "showCta": {
            "type": "boolean",
            "default": true
        }
    },
    "textdomain": "acesso-uporto",
    "editorScript": "file:./editor.js",
    "render": "file:./render.php"
}
