{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "acesso/cta",
    "version": "1.0.0",
    "title": "Call to Action",
    "category": "acesso-blocks",
    "icon": "megaphone",
    "description": "Call to action section with title, text, and button.",
    "keywords": [
        "cta",
        "call to action",
        "button",
        "banner"
    ],
    "supports": {
        "html": false,
        "align": [
            "wide",
            "full"
        ],
        "spacing": {
            "padding": true,
            "margin": true,
            "blockGap": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true,
            "__experimentalLetterSpacing": true,
            "__experimentalTextTransform": true
        }
    },
    "attributes": {
        "title": {
            "type": "string",
            "default": "Pronto para começar a tua jornada?"
        },
        "text": {
            "type": "string",
            "default": "Descobre os cursos disponíveis na U.Porto e encontra o teu futuro."
        },
        "primaryButtonText": {
            "type": "string",
            "default": "Explorar Cursos"
        },
        "primaryButtonUrl": {
            "type": "string",
            "default": "#cursos"
        },
        "secondaryButtonText": {
            "type": "string",
            "default": ""
        },
        "secondaryButtonUrl": {
            "type": "string",
            "default": ""
        },
        "variant": {
            "type": "string",
            "default": "gradient"
        },
        "backgroundImage": {
            "type": "string",
            "default": ""
        },
        "backgroundImageId": {
            "type": "number",
            "default": 0
        },
        "backgroundSize": {
            "type": "string",
            "default": "cover"
        },
        "backgroundPosition": {
            "type": "string",
            "default": "center center"
        },
        "backgroundRepeat": {
            "type": "string",
            "default": "no-repeat"
        },
        "backgroundAttachment": {
            "type": "string",
            "default": "scroll"
        },
        "pixelBackground": {
            "type": "string",
            "default": ""
        },
        "overlayOpacity": {
            "type": "number",
            "default": 85
        }
    },
    "textdomain": "acesso-uporto",
    "editorScript": "file:./editor.js",
    "render": "file:./render.php"
}
