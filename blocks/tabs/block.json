{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "acesso/tabs",
    "version": "1.0.0",
    "title": "Tabs",
    "category": "acesso-blocks",
    "icon": "index-card",
    "description": "Separadores com títulos e conteúdo. Substitui o ld_tabs do Visual Composer.",
    "keywords": [
        "tabs",
        "separadores",
        "ld_tabs"
    ],
    "supports": {
        "html": false,
        "align": [
            "wide",
            "full"
        ],
        "spacing": {
            "padding": true,
            "margin": true,
            "blockGap": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true,
            "__experimentalLetterSpacing": true,
            "__experimentalTextTransform": true
        }
    },
    "attributes": {
        "align": {
            "type": "string",
            "default": "wide"
        }
    },
    "textdomain": "acesso-uporto",
    "editorScript": "file:./editor.js",
    "render": "file:./render.php"
}
