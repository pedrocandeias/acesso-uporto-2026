{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "acesso/hero",
    "version": "1.0.0",
    "title": "Hero Section",
    "category": "acesso-blocks",
    "icon": "cover-image",
    "description": "Full-width hero section with rotating text animation and gradient overlay.",
    "keywords": ["hero", "banner", "header", "slider"],
    "supports": {
        "html": false,
        "align": ["full", "wide"]
    },
    "attributes": {
        "backgroundImage": {
            "type": "string",
            "default": ""
        },
        "backgroundImageId": {
            "type": "number",
            "default": 0
        },
        "backgroundSize": {
            "type": "string",
            "default": "cover"
        },
        "backgroundPosition": {
            "type": "string",
            "default": "center center"
        },
        "backgroundRepeat": {
            "type": "string",
            "default": "no-repeat"
        },
        "backgroundAttachment": {
            "type": "string",
            "default": "scroll"
        },
        "pixelBackground": {
            "type": "string",
            "default": ""
        },
        "rotatingWords": {
            "type": "array",
            "default": ["Conhecimento", "Investigação", "Inovação", "Futuro"]
        },
        "staticTextBefore": {
            "type": "string",
            "default": "ISTO É"
        },
        "mainTitle": {
            "type": "string",
            "default": "U.PORTO"
        },
        "tagline": {
            "type": "string",
            "default": "...e tu também podes ser!"
        },
        "primaryButtonText": {
            "type": "string",
            "default": "Explorar Cursos"
        },
        "primaryButtonUrl": {
            "type": "string",
            "default": "#cursos"
        },
        "secondaryButtonText": {
            "type": "string",
            "default": "Ver Vídeo"
        },
        "secondaryButtonUrl": {
            "type": "string",
            "default": ""
        },
        "useGradient": {
            "type": "boolean",
            "default": true
        },
        "gradientStart": {
            "type": "string",
            "default": "#572ddf"
        },
        "gradientEnd": {
            "type": "string",
            "default": "#da2489"
        },
        "overlayOpacity": {
            "type": "number",
            "default": 70
        },
        "minHeight": {
            "type": "string",
            "default": "100vh"
        },
        "rotatingColor": { "type": "string", "default": "" },
        "rotatingSize": { "type": "string", "default": "" },
        "titleColor": { "type": "string", "default": "" },
        "titleSize": { "type": "string", "default": "" },
        "taglineColor": { "type": "string", "default": "" },
        "taglineSize": { "type": "string", "default": "" },
        "primaryBtnBg": { "type": "string", "default": "" },
        "primaryBtnColor": { "type": "string", "default": "" },
        "secondaryBtnColor": { "type": "string", "default": "" },
        "buttonSize": { "type": "string", "default": "" }
    },
    "textdomain": "acesso-uporto",
    "editorScript": "file:./editor.js",
    "render": "file:./render.php"
}
