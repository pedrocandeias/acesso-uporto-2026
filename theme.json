{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "color": {
            "custom": true,
            "customDuotone": true,
            "customGradient": true,
            "defaultDuotone": false,
            "defaultGradients": false,
            "defaultPalette": false,
            "palette": [
                {
                    "slug": "purple",
                    "color": "#572ddf",
                    "name": "Purple"
                },
                {
                    "slug": "pink",
                    "color": "#da2489",
                    "name": "Pink"
                },
                {
                    "slug": "dark",
                    "color": "#060221",
                    "name": "Dark"
                },
                {
                    "slug": "cyan",
                    "color": "#00d084",
                    "name": "Cyan"
                },
                {
                    "slug": "lavender",
                    "color": "#8887e2",
                    "name": "Lavender"
                },
                {
                    "slug": "coral",
                    "color": "#ff6b6b",
                    "name": "Coral"
                },
                {
                    "slug": "white",
                    "color": "#ffffff",
                    "name": "White"
                },
                {
                    "slug": "light-gray",
                    "color": "#f5f5f5",
                    "name": "Light Gray"
                }
            ],
            "gradients": [
                {
                    "slug": "purple-pink",
                    "gradient": "linear-gradient(135deg, #572ddf 0%, #da2489 100%)",
                    "name": "Purple to Pink"
                },
                {
                    "slug": "pink-purple",
                    "gradient": "linear-gradient(135deg, #da2489 0%, #572ddf 100%)",
                    "name": "Pink to Purple"
                },
                {
                    "slug": "purple-dark",
                    "gradient": "linear-gradient(180deg, #572ddf 0%, #060221 100%)",
                    "name": "Purple to Dark"
                }
            ]
        },
        "typography": {
            "customFontSize": true,
            "fontFamilies": [
                {
                    "fontFamily": "'Barlow', sans-serif",
                    "slug": "barlow",
                    "name": "Barlow"
                },
                {
                    "fontFamily": "'Barlow Semi Condensed', sans-serif",
                    "slug": "barlow-condensed",
                    "name": "Barlow Semi Condensed"
                }
            ],
            "fontSizes": [
                {
                    "slug": "small",
                    "size": "0.875rem",
                    "name": "Small"
                },
                {
                    "slug": "medium",
                    "size": "1rem",
                    "name": "Medium"
                },
                {
                    "slug": "large",
                    "size": "1.25rem",
                    "name": "Large"
                },
                {
                    "slug": "x-large",
                    "size": "1.5rem",
                    "name": "Extra Large"
                },
                {
                    "slug": "xx-large",
                    "size": "2rem",
                    "name": "2X Large"
                },
                {
                    "slug": "huge",
                    "size": "3rem",
                    "name": "Huge"
                }
            ]
        },
        "spacing": {
            "padding": true,
            "margin": true,
            "units": ["px", "em", "rem", "%", "vw", "vh"],
            "spacingSizes": [
                {
                    "slug": "10",
                    "size": "0.5rem",
                    "name": "1"
                },
                {
                    "slug": "20",
                    "size": "1rem",
                    "name": "2"
                },
                {
                    "slug": "30",
                    "size": "2rem",
                    "name": "3"
                },
                {
                    "slug": "40",
                    "size": "4rem",
                    "name": "4"
                },
                {
                    "slug": "50",
                    "size": "6rem",
                    "name": "5"
                }
            ]
        },
        "layout": {
            "contentSize": "1200px",
            "wideSize": "1400px"
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "custom": {
            "spacing": {
                "small": "1rem",
                "medium": "2rem",
                "large": "4rem",
                "outer": "6rem"
            },
            "typography": {
                "lineHeight": {
                    "small": 1.2,
                    "medium": 1.5,
                    "large": 1.9
                }
            }
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--white)",
            "text": "var(--wp--preset--color--dark)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--barlow)",
            "fontSize": "var(--wp--preset--font-size--medium)",
            "lineHeight": "1.9"
        },
        "spacing": {
            "blockGap": "var(--wp--preset--spacing--30)"
        },
        "elements": {
            "h1": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--barlow-condensed)",
                    "fontSize": "clamp(2.5rem, 5vw, 3.5rem)",
                    "fontWeight": "600",
                    "lineHeight": "1.2"
                },
                "color": {
                    "text": "var(--wp--preset--color--dark)"
                }
            },
            "h2": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--barlow-condensed)",
                    "fontSize": "clamp(2rem, 4vw, 2.75rem)",
                    "fontWeight": "700",
                    "lineHeight": "1.2"
                },
                "color": {
                    "text": "var(--wp--preset--color--dark)"
                }
            },
            "h3": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--barlow-condensed)",
                    "fontSize": "clamp(1.5rem, 3vw, 2rem)",
                    "fontWeight": "700",
                    "lineHeight": "1.3"
                }
            },
            "h4": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--barlow-condensed)",
                    "fontSize": "1.5rem",
                    "fontWeight": "700"
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--purple)"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--pink)"
                    }
                }
            },
            "button": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--barlow)",
                    "fontSize": "1rem",
                    "fontWeight": "600",
                    "textTransform": "uppercase",
                    "letterSpacing": "0.5px"
                },
                "color": {
                    "background": "var(--wp--preset--color--purple)",
                    "text": "var(--wp--preset--color--white)"
                },
                "border": {
                    "radius": "50px"
                },
                "spacing": {
                    "padding": {
                        "top": "0.875rem",
                        "bottom": "0.875rem",
                        "left": "2rem",
                        "right": "2rem"
                    }
                },
                ":hover": {
                    "color": {
                        "background": "var(--wp--preset--color--pink)"
                    }
                }
            }
        },
        "blocks": {
            "core/button": {
                "border": {
                    "radius": "50px"
                },
                "typography": {
                    "fontWeight": "600",
                    "textTransform": "uppercase"
                }
            },
            "core/heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--barlow-condensed)"
                }
            },
            "core/paragraph": {
                "typography": {
                    "lineHeight": "1.9"
                }
            },
            "core/columns": {
                "spacing": {
                    "blockGap": "var(--wp--preset--spacing--30)"
                }
            },
            "core/group": {
                "spacing": {
                    "padding": {
                        "top": "var(--wp--preset--spacing--40)",
                        "bottom": "var(--wp--preset--spacing--40)"
                    }
                }
            }
        }
    },
    "templateParts": [
        {
            "name": "header",
            "title": "Header",
            "area": "header"
        },
        {
            "name": "footer",
            "title": "Footer",
            "area": "footer"
        }
    ],
    "customTemplates": [
        {
            "name": "blank",
            "title": "Blank",
            "postTypes": ["page", "post"]
        },
        {
            "name": "full-width",
            "title": "Full Width",
            "postTypes": ["page"]
        }
    ]
}
